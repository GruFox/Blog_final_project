@model Blog_final_project.Models.EditRoleViewModel

@{
	ViewData["Title"] = "EditRole";
}

<script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.17.0/jquery.validate.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/jquery.validation.unobtrusive/3.2.10/jquery.validate.unobtrusive.min.js"></script>

<div class="block-reg background-white">
    <h3 class="center">Редактирование роли</h3>

    <form class="frm" method="post" asp-controller="Roles" asp-action="Edit">
        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" asp-for="Id" />
        <div>

            <div class="mrgn">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span><br />
            </div>

            <div class="mrgn">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span><br />
            </div>
        </div>

        <div class="center">
            <input class="btn_submit" type="submit" value="Сохранить" />
        </div>
    </form>

    <div>
        <a
            class="page_role"
            asp-area=""
            asp-controller="Roles"
            asp-action="Index">
            Перейти к списку всех ролей
       </a>
    </div>

</div>
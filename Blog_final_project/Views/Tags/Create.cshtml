@model Blog_final_project.Models.CreateTagViewModel

@{
    ViewData["Title"] = "CreateTag";
}

<script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.17.0/jquery.validate.min.js"></script>
<script src="https://ajax.aspnetcdn.com/ajax/jquery.validation.unobtrusive/3.2.10/jquery.validate.unobtrusive.min.js"></script>

<div class="block-reg background-white">
    <h3 class="center">Добавлене тега</h3>

    <form class="frm" method="post" asp-controller="Tags" asp-action="Create">
        <div asp-validation-summary="ModelOnly"></div>
        <div>
            <div class="mrgn">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Введите название тега" />
                <span asp-validation-for="Name" class="text-danger"></span><br />
            </div>
        </div>

        <div class="center">
            <input class="btn_submit" type="submit" value="Добавить" />
        </div>
    </form>

    <div>
        <a class="page_tag"
            asp-area=""
            asp-controller="Tags"
            asp-action="Index">
            Перейти к списку всех тегов
        </a>
    </div>

</div>
@model Blog_final_project.Models.ArticleViewModel

@{
	ViewData["Title"] = "IndexArticles";
}

<div class="show-article">
    <h3 class="center">Все статьи</h3>
    
    <div class="block-show background-white">
        @if (Model.Articles.Count != 0)
        {
            @foreach (var article in Model.Articles)
            {
                <div class="show-article">

                    <div class="mrgn center-align">
                        <a class="details_article"
                            asp-area=""
                            asp-controller="Articles"
                            asp-action="Details"
                            asp-route-id="@article.Id">
                            <h4>@article.Title</h4>
                        </a>
                    </div>

                    <div class="mrgn center-align">
                        @foreach (var tag in article.Tags)
                        {
                            <p>@tag.Name</p>
                        }
                    </div>

                    @if (User.IsInRole("Admin") || User.Identity?.Name == article.Author.UserName)
                    {
                        <div class="mrgn center-align">

                            <a class="btn btn-secondary"
                               asp-controller="Articles"
                               asp-action="Edit"
                               asp-route-id="@article.Id">
                               Редактировать
                            </a>

                            <form asp-controller="Articles"
                                  asp-action="Delete"
                                  asp-route-id="@article.Id"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-danger">
                                    Удалить
                                </button>
                            </form>

                        </div>
                    }

                </div>
            }
        }
        else
        {
            <div>
                <label> Поиск не дал результатов.</label>
            </div>
        }
    </div>

    <a
        class="create_article"
        asp-area=""
        asp-controller="Articles"
        asp-action="Create">
        Добавить статью
    </a>

</div>
